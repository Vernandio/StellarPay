# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
# ...but Expo's web export vendors the icon fonts under
# dist/assets/vendor/. The blanket ignore above also matches that path,
# which silently drops every icon .ttf from the committed dist/ — so on the
# Vercel deploy the fonts 404, get served index.html, and all icons render as
# missing-glyph "tofu" boxes. Keep the exported dist node_modules.
!dist/**/node_modules/
!dist/**/node_modules/**

# Expo
.expo/
backend/dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.local
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

serviceAccountKey.json